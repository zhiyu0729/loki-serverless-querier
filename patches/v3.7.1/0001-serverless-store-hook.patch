+func (t *Loki) wrapServerlessStore() error {
+	cfg := t.Cfg.ServerlessStore
+	cfg.SetDefaults()
+	if err := cfg.Validate(); err != nil {
+		return err
+	}
+
+	backend, err := serverlessbackend.New(context.Background(), cfg)
+	if err != nil {
+		return err
+	}
+	storeExecutor := executor.NewServerlessStoreExecutor(backend.Invoker(), backend.ObjectStore(), executor.Options{
+		MaxInterval:              cfg.MaxInterval,
+		MinInterval:              cfg.MinInterval,
+		MaxConcurrent:            cfg.MaxConcurrent,
+		InlineRequestLimitBytes:  cfg.InlineRequestLimitBytes,
+		InlineResponseLimitBytes: cfg.InlineResponseLimitBytes,
+		MaxInvokePayloadBytes:    backend.Capabilities().MaxInvokePayloadBytes,
+		FallbackOnFailure:        cfg.FallbackOnFailure,
+	})
+	t.Store = lokistore.Wrap(t.Store, storeExecutor, buildinfo.LokiVersion, buildinfo.OverlayVersion, cfg.FallbackOnFailure)
+	level.Info(util_log.Logger).Log("msg", "serverless store wrapper enabled", "provider", backend.Provider(), "max_interval", cfg.MaxInterval, "max_concurrent", cfg.MaxConcurrent)
+	return nil
+}
